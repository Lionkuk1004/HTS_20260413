; =========================================================================
; HTS64_Native_ECCM_Core.def
; Windows 호스트 DLL/테스트 선택 — Cortex-M 정적 링크 시 미사용
; EXPORTS 절 없음: HTS_LIM 정적 라이브(.lib) 빌드에서 TU 내부 연결
;
; [기준서 정합] V(ECCM 전용 항목 없음)·W(DMA/WDT 등 본 TU 비해당)
; D-2 / X-5-1 보안 소거는 HTS_Secure_Memory.cpp Force_Secure_Wipe 경유 — 본 DEF는 심볼 미노출
; =========================================================================

LIBRARY HTS64_Native_ECCM_Core

DESCRIPTION "HTS B-CDMA 64-chip ECCM native core (Walsh-Hadamard FWHT, D-2/X-5-1 SecureMemory)"
