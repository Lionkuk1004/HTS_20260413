  <!-- libiio 기본 설치 경로 — 다르면 사용자 Directory.Build.props 등에서 LibIioRoot 재정의 -->
  <PropertyGroup>
    <LibIioRoot>C:\Program Files\libiio</LibIioRoot>
    <!--
      LibIioStaticConsumer:
        false (기본) = DLL + import lib (libiio.lib). __imp_iio_* 링크.
        true         = 정적 libiio(.lib에 구현 포함) 사용 시. iio.h에 LIBIIO_STATIC 필요.
      정적/DLL 혼동 시 LNK2001이 나므로 설치본에 맞게 조정.
    -->
    <LibIioStaticConsumer>false</LibIioStaticConsumer>
    <LibIioLibDirs>$(LibIioRoot)\lib;$(LibIioRoot)\lib\$(Platform);$(LibIioRoot)\lib\$(Platform)\Release;$(LibIioRoot)\lib\$(Platform)\Debug;$(LibIioRoot)\lib\$(Platform)\RelWithDebInfo;$(LibIioRoot)\lib\Release;$(LibIioRoot)\lib\Debug;$(LibIioRoot)\lib\RelWithDebInfo;$(LibIioRoot)\lib\$(Configuration);$(LibIioRoot)\lib\$(Platform)\$(Configuration)</LibIioLibDirs>
    <LibIioCppDefines Condition="'$(LibIioStaticConsumer)'=='true'">LIBIIO_STATIC</LibIioCppDefines>
    <LibIioCppDefines Condition="'$(LibIioStaticConsumer)'!='true'"></LibIioCppDefines>
  </PropertyGroup>
  <ItemDefinitionGroup Condition="'$(Configuration)|$(Platform)'=='Debug|x64'">
